{
  "name": "idea-search",
  "displayName": "IDEA Search",
  "description": "IntelliJ IDEA-like search experience for VS Code — floating popup, multi-tab sessions, custom scopes",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:idea-search.findInFiles",
    "onCommand:idea-search.searchEverywhere",
    "onCommand:idea-search.manageScopes"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "idea-search.findInFiles",
        "title": "Find in Files (IDEA Style)",
        "category": "IDEA Search"
      },
      {
        "command": "idea-search.searchEverywhere",
        "title": "Search Everywhere",
        "category": "IDEA Search"
      },
      {
        "command": "idea-search.manageScopes",
        "title": "Manage Custom Scopes",
        "category": "IDEA Search"
      }
    ],
    "keybindings": [
      {
        "command": "idea-search.findInFiles",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus || editorFocus || terminalFocus || sideBarFocus || panelFocus"
      },
      {
        "command": "idea-search.searchEverywhere",
        "key": "ctrl+alt+shift+f",
        "mac": "cmd+alt+shift+f",
        "when": "editorTextFocus || editorFocus || terminalFocus || sideBarFocus || panelFocus"
      }
    ],
    "configuration": {
      "title": "IDEA Search",
      "properties": {
        "idea-search.maxTabs": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum number of search tabs to keep open in the panel"
        },
        "idea-search.showPreviewInSearchEverywhere": {
          "type": "boolean",
          "default": true,
          "description": "Show file preview panel in Search Everywhere"
        },
        "idea-search.maxFilesToSearch": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "maximum": 50000,
          "description": "Maximum number of files to search (larger values may be slow)"
        },
        "idea-search.defaultScope": {
          "type": "string",
          "default": "project",
          "enum": [
            "project",
            "open-files",
            "current-file",
            "git-changed"
          ],
          "description": "Default scope for Find in Files"
        },
        "idea-search.excludeBinaryExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "bin",
            "exe",
            "dll",
            "so",
            "dylib",
            "obj",
            "o",
            "jar",
            "war",
            "ear",
            "class",
            "zip",
            "tar",
            "gz",
            "bz2",
            "xz",
            "7z",
            "rar",
            "png",
            "jpg",
            "jpeg",
            "gif",
            "bmp",
            "ico",
            "webp",
            "svg",
            "mp3",
            "mp4",
            "wav",
            "avi",
            "mov",
            "mkv",
            "flac",
            "pdf",
            "doc",
            "docx",
            "xls",
            "xlsx",
            "ppt",
            "pptx",
            "woff",
            "woff2",
            "ttf",
            "otf",
            "eot",
            "db",
            "sqlite",
            "sqlite3",
            "dmg",
            "pkg",
            "app",
            "ipa",
            "a",
            "framework"
          ],
          "description": "File extensions to exclude from search results (without leading dot). Set to [] to disable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  }
}
